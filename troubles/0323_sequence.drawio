      <mxGeometry x="420" y="300" width="260" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="m5n" value="防衛反応: 外部データで&#xa;正当性を回復したい" style="text;html=1;fontSize=11;fontColor=#cc0000;align=left;whiteSpace=wrap;" vertex="1" parent="1">
