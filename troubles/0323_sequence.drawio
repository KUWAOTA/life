    <!-- Turn 10 -->
    <mxCell id="t10" value="拓磨「何が問題だった、口調」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="120" y="860" width="280" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="t10n" value="意図: 普段通りの&#xa;振り返りの問いかけ" style="text;html=1;fontSize=11;fontColor=#999999;align=right;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="-10" y="860" width="120" height="40" as="geometry"/>
    </mxCell>

    <!-- Key insight box -->
    <mxCell id="box" value="同じ言葉が状態によって意味が変わる&#xa;&#xa;【平常時】「何が問題だった？」&#xa; → 一緒に振り返ろう（協働）&#xa;&#xa;【洪水時】「何が問題だった？」&#xa; → 正解を答えろ（試験）&#xa; → 答えられない = この対話は終わらない（脅威）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
      <mxGeometry x="420" y="840" width="330" height="140" as="geometry"/>
    </mxCell>

    <!-- Arrow from t10 to box -->
    <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="t10" target="box" parent="1">
