<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Phase 1 Header -->
    <mxCell id="p1" value="Phase 1: 土俵の奪い合い" style="text;html=1;fontSize=16;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;whiteSpace=wrap;align=center;" vertex="1" parent="1">
      <mxGeometry x="160" y="0" width="480" height="40" as="geometry"/>
    </mxCell>

    <!-- Turn 1 -->
    <mxCell id="m1" value="萌子「お湯で入れてほしい」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="420" y="60" width="260" height="40" as="geometry"/>
