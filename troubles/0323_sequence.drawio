    <mxCell id="cry" value="萌子 泣き出す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996185;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="420" y="720" width="260" height="40" as="geometry"/>
