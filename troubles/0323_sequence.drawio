    </mxCell>
    <mxCell id="t4r" value="⚡ 萌子の受信:&#xa;「感覚を個人の偏りに格下げされた」" style="text;html=1;fontSize=11;fontColor=#cc0000;align=left;whiteSpace=wrap;" vertex="1" parent="1">
