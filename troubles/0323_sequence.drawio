    </mxCell>

    <!-- Phase 2 Header -->
    <mxCell id="p2" value="Phase 2: 一方的な判決" style="text;html=1;fontSize=16;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;whiteSpace=wrap;align=center;" vertex="1" parent="1">
      <mxGeometry x="160" y="370" width="480" height="40" as="geometry"/>
    </mxCell>

    <!-- Turn 6 -->
