    </mxCell>
    <mxCell id="t2r" value="⚡ 萌子の受信:&#xa;「私の要望は非合理ということ？」" style="text;html=1;fontSize=11;fontColor=#cc0000;align=left;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="420" y="115" width="250" height="40" as="geometry"/>
    </mxCell>

    <!-- Turn 3 -->
    <mxCell id="m3" value="萌子「水道水で作るん違うくない」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="420" y="180" width="260" height="40" as="geometry"/>
    </mxCell>

    <!-- Turn 4 -->
    <mxCell id="t4" value="拓磨「それは萌子のこだわりやなあ」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="120" y="240" width="280" height="40" as="geometry"/>
