    </mxCell>
    <mxCell id="t9r" value="⚡ 萌子の受信: 圧力として受信&#xa;（分析的入力を処理できない状態）" style="text;html=1;fontSize=11;fontColor=#cc0000;align=left;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="420" y="785" width="280" height="40" as="geometry"/>
