    </mxCell>
    <mxCell id="t6r" value="⚡ 萌子の受信:&#xa;「判決が出た。私は参加していない」&#xa;「貸しにされた」" style="text;html=1;fontSize=11;fontColor=#cc0000;align=left;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="420" y="425" width="260" height="55" as="geometry"/>
    </mxCell>

    <!-- Turn 7 -->
    <mxCell id="m7" value="萌子「拓磨が作るときは水でいいやん。&#xa;時給換算2分にしといて」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
