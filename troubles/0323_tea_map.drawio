                <mxCell id="title" value="お茶問題：ポジションと利害の地図" style="text;html=1;fontSize=18;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="100" y="10" width="700" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="tname" value="拓磨" style="text;html=1;fontSize=16;fontStyle=1;align=center;fontColor=#2d6a2d;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="tp" value="【ポジション（表明された主張）】&#xa;「水でもOK。パッケージにも書いてある。&#xa;わざわざお湯を沸かすのは手間」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="20" y="100" width="250" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="te" value="【今ある感情（俎上）】&lt;br&gt;・合理的判断を尊重してほしい&lt;br&gt;・手順を強制されることへの抵抗&lt;br&gt;・誤って水で作ったとき怒られる不安" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="20" y="200" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ti" value="【根底にある利害（Interests）】&#xa;① 認知負荷を増やしたくない&#xa;② 間違えても責められない安心感&#xa;③ 意思決定の合理性を尊重されたい&#xa;④ 義務感なく家事をしたい" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="20" y="330" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="mname" value="萌子" style="text;html=1;fontSize=16;fontStyle=1;align=center;fontColor=#8b2252;" parent="1" vertex="1">
                    <mxGeometry x="660" y="60" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="mp" value="【ポジション（表明された主張）】&#xa;「お湯で入れてほしい。&#xa;水道水で作るのは嫌」" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="640" y="100" width="250" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="me" value="【今ある感情（俎上）】&#xa;・感覚的な嫌悪感を「こだわり」と片付けられた&#xa;・自分の主張を通す正当な手段がない&#xa;・折り合いを探したのに無効化された&#xa;・話し合いで消耗した疲弊感" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="640" y="200" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="mi" value="【根底にある利害（Interests）】&#xa;① 感覚的な不快感を解消したい&#xa;② 感覚の好みが尊重されたい&#xa;③ 「非合理」とレッテルを貼られたくない&#xa;④ 二人で決めたという感覚がほしい" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="640" y="330" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="overlap_title" value="利害の重なり" style="text;html=1;fontSize=13;fontStyle=1;align=center;" parent="1" vertex="1">
